{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information including wallet balance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "balance": { "type": "number", "description": "Current wallet balance in USD" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "balance"]
    },
    "Transaction": {
      "title": "Wallet Transaction",
      "description": "Records of deposits, withdrawals, and purchases.",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "purchase"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and wallet balances."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction log (can be queried by userId)."
    }
  }
}
